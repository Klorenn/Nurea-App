# Copia este archivo a .env.local y rellena los valores.
# Para que los correos de verificación se envíen:
# 1. Crea una API key en https://resend.com/api-keys
# 2. Verifica tu dominio en https://resend.com/domains
# 3. Añade las variables a .env.local

# =============================================================================
# SUPABASE
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # ⚠️ NUNCA exponer en cliente

# =============================================================================
# STRIPE (Suscripciones SaaS)
# =============================================================================
# Claves de API (Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=sk_live_xxx          # O sk_test_xxx para desarrollo
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx  # O pk_test_xxx

# Webhook Secret (Dashboard > Developers > Webhooks > Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# IDs de Precios (Dashboard > Products > Selecciona producto > Pricing)
# Plan Starter
NEXT_PUBLIC_STRIPE_PRICE_STARTER_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_STARTER_YEARLY=price_xxx

# Plan Professional
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_xxx

# Plan Clinic
NEXT_PUBLIC_STRIPE_PRICE_CLINIC_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_CLINIC_YEARLY=price_xxx

# =============================================================================
# EMAIL (Resend)
# =============================================================================
RESEND_API_KEY=re_xxxxxxxx
SECURITY_EMAIL_FROM=NUREA <notificaciones@nurea.app>

# =============================================================================
# OPCIONAL
# =============================================================================
NEXT_PUBLIC_SITE_URL=https://nurea.app

# =============================================================================
# REVENUECAT & STELLAR X402 (Pagos Híbridos)
# =============================================================================
NEXT_PUBLIC_REVENUECAT_API_KEY=test_xxx
REVENUECAT_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET # O PUBLIC
NEXT_PUBLIC_NUREA_STELLAR_WALLET=GXXX...

